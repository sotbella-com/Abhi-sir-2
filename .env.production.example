# ─────────────────────────────────────────────────────────────────────────────
# SÖTBELLA storefront — PRODUCTION env TEMPLATE
#
# Fill these on the PRODUCTION Railway service's Variables (NOT committed to git).
# VITE_* values are baked into the public browser bundle at build time — anything
# here marked (⚠ PUBLIC) ships to every visitor's browser. Do NOT put a real
# secret in a VITE_* var unless you accept it being public. See the SECURITY note
# at the bottom before go-live.
# ─────────────────────────────────────────────────────────────────────────────

# ── AYRA copilot ──
VITE_AYRA_ENABLED=true
VITE_AYRA_SANDBOX=false                       # false in prod → AYRA test-pixel events OFF (prod tracking via GTM)
VITE_AYRA_SESSION_URL=https://<prod-broker-host>/session
VITE_AYRA_DNA_URL=https://<prod-broker-host>/ayra/dna       # optional; derived from SESSION_URL if unset
VITE_AYRA_JOURNEY_URL=https://<prod-broker-host>/ayra/journey  # optional; derived if unset
VITE_AYRA_LIVE_URL=https://<prod-broker-host>/ayra/live        # optional; derived if unset
VITE_AYRA_OFFERS=                              # optional JSON offer array; else built-in defaults
VITE_AYRA_TEST_PIXEL_ID=                       # leave BLANK in prod (test-only)
VITE_AYRA_TEST_EVENT_CODE=                     # leave BLANK in prod (test-only)

# ── SFCC B2C Commerce (PRODUCTION instance) ──
VITE_SFCC_SHORTCODE=<prod-shortcode>           # prod SCAPI short code (staging was dyp4l3dm)
VITE_SFCC_SHORT_CODE=<prod-shortcode>          # both spellings are read in code — set both the same
VITE_SFCC_ORG_ID=<prod-org-id>                 # e.g. f_ecom_XXXX_prd (staging was f_ecom_blxz_stg)
VITE_SFCC_SITE_ID=sotbella_in
VITE_SFCC_LOCALE=en-IN
VITE_SFCC_CLIENT_ID=<prod-slas-client-id>      # client id is not secret (public ok)
VITE_SFCC_CLIENT_SECRET=                        # LEAVE BLANK in prod → token mint moves server-side (see SERVER block)
VITE_SFCC_BASE_URL=/sfcc                       # keep "/sfcc" → server.cjs same-origin proxy (no CORS)
VITE_SFCC_BASIC_AUTH_USERNAME=<if used>        # ⚠ PUBLIC if set
VITE_SFCC_BASIC_AUTH_PASSWORD=<if used>        # ⚠ PUBLIC if set
VITE_SFCC_PASSWORDLESS_CALLBACK_URL=https://apisfcc.sotbella.com/on/demandware.store/Sites-sotbella_in-Site/en_IN/Pwdless-Callback
VITE_SFCC_STATIC_USID=<if used>

# Also update server.cjs proxy target if prod SFCC is a different host than dyp4l3dm.

# ── Payments ──
VITE_BREEZE_KEY_ID=<prod-breeze-key>
VITE_BREEZE_SHOP_URL=<prod-breeze-shop-url>
VITE_STRIPE_PUBLISHABLE_KEY=<prod-stripe-pk>   # publishable key — safe to be public
VITE_WALLET_API_URL=https://live-wallet.sotbella360.com/api
VITE_WALLET_API_KEY=<prod-wallet-key>          # ⚠ PUBLIC if set

# ── SFCC SERVER-SIDE token mint (server.cjs) — NOT in the browser bundle ──
# The prod SLAS secret lives ONLY here. server.cjs /sfcc-token injects it; the
# browser never sees it. (No VITE_ prefix → not baked into the bundle.)
SFCC_CLIENT_ID=<prod-slas-client-id>
SFCC_CLIENT_SECRET=<prod-slas-secret>          # server-only secret — the safe home for it
SFCC_ORG_ID=<prod-org-id>
SFCC_HOST=https://<prod-shortcode>.api.commercecloud.salesforce.com

# ── Integrations ──
VITE_TAILOREDD_API_KEY=<prod-tailoredd-key>    # ⚠ PUBLIC if set
VITE_TAILOREDD_MERCHANT_ID=<prod-merchant-id>
VITE_GOOGLE_MAPS_API_KEY=<prod-maps-key>       # ⚠ restrict by HTTP referrer in Google console
VITE_IMAGE_URL=<prod-image-cdn>
VITE_API_URL=<prod-api-base>
VITE_BASE_URL=https://www.sotbella.com

# ─────────────────────────────────────────────────────────────────────────────
# SECURITY / GO-LIVE (read before flipping prod):
#  1. The SLAS token exchange runs in the BROWSER (authTokenManager.js) with
#     VITE_SFCC_CLIENT_SECRET baked into the public bundle. Shipping a REAL prod
#     secret this way exposes it to anyone. BEFORE go-live, move the client-
#     credentials token mint into server.cjs (same place that proxies /sfcc) and
#     have the browser call that — so the secret never leaves the server.
#  2. Set every value above as PRODUCTION Railway variables — do NOT commit a
#     filled .env. This template stays as .env.production.example only.
#  3. VITE_AYRA_SANDBOX=false disables the test-pixel path; prod conversion
#     tracking flows through the storefront's existing GTM + Meta pixel/CAPI.
#  4. Point VITE_AYRA_SESSION_URL at a prod broker (fund ElevenLabs), or reuse
#     the sandbox broker with ALLOWED_ORIGINS updated to the prod origin.
#  5. The broker service has its own env — see ayra-ops/broker/.env.example.
# ─────────────────────────────────────────────────────────────────────────────
